# Authelia Configuration
JWT_SECRET=${AUTHELIA_JWT_SECRET}
SESSION_SECRET=${AUTHELIA_SESSION_SECRET}
STORAGE_ENCRYPTION_KEY=${AUTHELIA_STORAGE_ENCRYPTION_KEY}

# Database
STORAGE_POSTGRES_HOST=homelab-postgres
STORAGE_POSTGRES_PORT=5432
STORAGE_POSTGRES_USERNAME=${DB_POSTGRES_USER}
STORAGE_POSTGRES_PASSWORD=${DB_POSTGRES_PASSWORD}
STORAGE_POSTGRES_DATABASE=authelia_db

# SMTP
NOTIFIER_SMTP_HOST=smtp.gmail.com
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USERNAME=your-email@gmail.com
NOTIFIER_SMTP_PASSWORD=your-app-password
NOTIFIER_SMTP_SENDER=authelia@example.com

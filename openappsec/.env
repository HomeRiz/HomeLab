# open-appsec configuration
# Docs: https://docs.openappsec.io

APPSEC_VERSION=latest

# Volume paths (relative to this directory)
APPSEC_CONFIG=./appsec-config
APPSEC_DATA=./appsec-data
APPSEC_LOGS=./appsec-logs
APPSEC_LOCALCONFIG=./appsec-localconfig
APPSEC_SMART_SYNC_STORAGE=./appsec-smartsync-storage
NGINX_CONFIG=./nginx-config

# User email shown in open-appsec Web UI
APPSEC_USER_EMAIL=user@email.com

# Agent token from https://my.openappsec.io (leave empty for standalone mode)
APPSEC_AGENT_TOKEN=

# Set to true for local declarative config; false when using the Web UI
APPSEC_AUTO_POLICY_LOAD=false

# Optional HTTPS proxy (e.g. user:password@proxy:port)
APPSEC_HTTPS_PROXY=

# Standalone mode: set COMPOSE_PROFILES=standalone to enable local learning.
# Required when APPSEC_AGENT_TOKEN is empty.
COMPOSE_PROFILES=

# Database used by appsec-tuning-svc (standalone mode).
# Defaults to the shared homelab postgres instance.
APPSEC_DB_HOST=postgres
APPSEC_DB_USER=postgres
APPSEC_DB_PASSWORD=

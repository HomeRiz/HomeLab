# Cloudflare Tunnel Configuration
# Get your tunnel token from: https://dash.cloudflare.com/

# Tunnel Name (must match the tunnel created in Cloudflare dashboard)
CLOUDFLARED_TUNNEL_NAME=homelab

# Tunnel Token (from Cloudflare dashboard - required for operation)
CLOUDFLARED_TUNNEL_TOKEN=change_me_tunnel_token_from_cloudflare

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=change_me_account_id

# Domain where your services will be exposed
CLOUDFLARE_DOMAIN=example.com

# Optional: Custom nameservers
CLOUDFLARE_NAMESERVERS=

# Additional configuration
CLOUDFLARED_LOG_LEVEL=info
CLOUDFLARED_METRICS=127.0.0.1:7834

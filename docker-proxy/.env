# Docker Socket Proxy - Tecnativa/docker-socket-proxy
# Security: Restrict access to Docker API through the proxy

# Container Operations
ALLOW_START=1
ALLOW_STOP=1
ALLOW_RESTART=1
ALLOW_PAUSE=1
ALLOW_UNPAUSE=1
ALLOW_KILL=0
ALLOW_RENAME=0

# Build & Pull Operations
ALLOW_BUILD=0
ALLOW_PULL=1
ALLOW_PUSH=0

# Delete Operations (High Risk - Keep Disabled)
ALLOW_DELETE=0
ALLOW_REMOVE=0

# Container Management
ALLOW_CREATE=0
ALLOW_RUN=0
ALLOW_EXEC=0

# Logging & Info
ALLOW_LOGS=1
ALLOW_LIST=1
ALLOW_INSPECT=1
ALLOW_STATS=1
ALLOW_STATUS=1

# Container Events
ALLOW_EVENTS=1

# Image Operations
ALLOW_IMAGE_BUILD=0
ALLOW_IMAGE_PULL=1
ALLOW_IMAGE_PUSH=0
ALLOW_IMAGE_DELETE=0
ALLOW_IMAGE_LIST=1
ALLOW_IMAGE_INSPECT=1

# Volume Operations
ALLOW_VOLUMES=1
ALLOW_VOLUME_CREATE=0
ALLOW_VOLUME_DELETE=0

# Network Operations
ALLOW_NETWORKS=1
ALLOW_NETWORK_CREATE=0
ALLOW_NETWORK_DELETE=0

# Node Operations
ALLOW_NODES=0

# Service Operations (Swarm)
ALLOW_SERVICES=0
ALLOW_TASKS=0

# CAPS & POST
ALLOW_POST=0
POST_ALLOW_LIST=/version,/images/json,/containers/json

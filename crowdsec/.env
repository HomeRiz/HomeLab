# CrowdSec Configuration
AGENT_USERNAME=${CROWDSEC_AGENT_USERNAME}
AGENT_PASSWORD=${CROWDSEC_AGENT_PASSWORD}
LAPI_LISTEN=${CROWDSEC_LAPI_LISTEN}
DB_BACKEND=sqlite

# Database
CROWDSEC_DB_PATH=/var/lib/crowdsec/data/crowdsec.db

# Logging
CROWDSEC_LOG_LEVEL=info

# Bouncer Configuration
CROWDSEC_BOUNCER_API_KEY=change_me_bouncer_api_key
CROWDSEC_BOUNCER_LAPI_URL=http://crowdsec:8080

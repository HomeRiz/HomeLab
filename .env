# HomeLab Production Environment
TZ=UTC
ENVIRONMENT=production

# ============================================
# CORE DATABASE CONFIGURATION
# ============================================
DB_POSTGRES_USER=homelab_admin
DB_POSTGRES_PASSWORD=ChangeMe123!@#
DB_POSTGRES_DB=homelab_main
DB_REDIS_PASSWORD=ChangeMe456!@#

# ============================================
# CADDY REVERSE PROXY & SSL
# ============================================
CADDY_API_PORT=2019
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_LOG_LEVEL=info
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_API_TOKEN=

# ============================================
# CERTIFICATE & SSL
# ============================================
CERTBOT_EMAIL=admin@example.com
CERTBOT_DOMAIN=example.com

# ============================================
# SECURITY INFRASTRUCTURE
# ============================================

# OpenAppSec
OPENAPPSEC_AGENT_TOKEN=change_me_openappsec_token
OPENAPPSEC_ORCHESTRATION_MODE=online

# CrowdSec
CROWDSEC_AGENT_USERNAME=homelab_agent
CROWDSEC_AGENT_PASSWORD=ChangeMe789!@#
CROWDSEC_LAPI_LISTEN=0.0.0.0:8080
CROWDSEC_BOUNCER_API_KEY=change_me_bouncer_api_key
CROWDSEC_BOUNCER_LAPI_URL=http://crowdsec:8080

# Authelia
AUTHELIA_JWT_SECRET=your_jwt_secret_change_me
AUTHELIA_SESSION_SECRET=your_session_secret_change_me
AUTHELIA_STORAGE_ENCRYPTION_KEY=your_encryption_key_change_me

# GeoIP
GEOIP_UPDATE_FREQUENCY=7

# ============================================
# PASSWORD MANAGEMENT (VAULTS)
# ============================================

# Vaultwarden
VAULTWARDEN_DOMAIN=vaultwarden.example.com
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=true
VAULTWARDEN_SHOW_PASSWORD_HINT=false
VAULTWARDEN_LOG_LEVEL=info
VAULTWARDEN_ADMIN_TOKEN=change_me_admin_token_long_random
DB_VAULTWARDEN_USER=vaultwarden_user
DB_VAULTWARDEN_PASSWORD=ChangeMe_VW_123!@#
DB_VAULTWARDEN_DB=vaultwarden

# Bitwarden
BITWARDEN_DOMAIN=bitwarden.example.com
BITWARDEN_ATTACHMENT_KEY=change_me_attachment_encryption_key
BITWARDEN_ENCRYPTION_KEY=change_me_core_encryption_key
BITWARDEN_CERT_THUMBPRINT=change_me_cert_thumbprint
BITWARDEN_DELETION_TOKEN=change_me_admin_deletion_token

# ============================================
# DNS & MAIL
# ============================================

# AdGuard Home
ADGUARD_UPSTREAM_DNS=8.8.8.8 8.8.4.4
ADGUARD_BOOTSTRAP_DNS=1.1.1.1:53
ADGUARD_SYNC_LOG_LEVEL=info

# Stalwart Mail
MAIL_DOMAIN=mail.example.com
DB_STALWART_USER=stalwart_user
DB_STALWART_PASSWORD=ChangeMe_Stalwart_123!@#
DB_STALWART_DB=stalwart_mail

# ============================================
# MONITORING & OBSERVABILITY
# ============================================

# Speedtest Tracker
SPEEDTEST_SCHEDULE=0 */6 * * *
SPEEDTEST_PRUNE_RESULTS=30
DB_SPEEDTEST_USER=speedtest_user
DB_SPEEDTEST_PASSWORD=ChangeMe_Speedtest_123!@#
DB_SPEEDTEST_DB=speedtest_tracker

# Dozzle
DOZZLE_LOG_LEVEL=info

# Glances
GLANCES_LOG_LEVEL=info

# ============================================
# DOCUMENT & CONTENT MANAGEMENT
# ============================================

# Paperless-NGX
PAPERLESS_SECRET_KEY=change_me_very_long_secret_key
PAPERLESS_SUPERUSER_USERNAME=admin
PAPERLESS_SUPERUSER_PASSWORD=ChangeMe_Paperless_123!@#
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=ChangeMe_Paperless_123!@#
DB_PAPERLESS_USER=paperless_user
DB_PAPERLESS_PASSWORD=ChangeMe_Paperless_DB_123!@#
DB_PAPERLESS_DB=paperless_ngx

# Hoarder
HOARDER_DOMAIN=hoarder.example.com
HOARDER_MEILI_KEY=change_me_meili_master_key
HOARDER_NEXTAUTH_SECRET=change_me_nextauth_secret

# ============================================
# DASHBOARDS
# ============================================

# Homepage
HOMEPAGE_TITLE=My Home Lab

# Dashy
DASHY_TITLE=My Dashboard

# ============================================
# PRODUCTIVITY & ORGANIZATION
# ============================================

# Homebox
HOMEBOX_LOG_LEVEL=info

# Firefly III
FIREFLY_APP_KEY=change_me_firefly_app_key_base64
DB_FIREFLY_USER=firefly_user
DB_FIREFLY_PASSWORD=ChangeMe_Firefly_123!@#
DB_FIREFLY_DB=firefly_iii

# Vikunja
VIKUNJA_LOG_LEVEL=info
DB_VIKUNJA_USER=vikunja_user
DB_VIKUNJA_PASSWORD=ChangeMe_Vikunja_123!@#
DB_VIKUNJA_DB=vikunja

# ============================================
# UTILITIES
# ============================================

# Stirling PDF
STIRLING_LOG_LEVEL=info

# Apprise
APPRISE_LOG_LEVEL=info

# Monocker
MONOCKER_LOG_LEVEL=info

# PortTracker
PORTRACKER_LOG_LEVEL=info

# ============================================
# NETWORK & SECURITY
# ============================================

# Netbird
NETBIRD_ADMIN_PASSWORD=ChangeMe999!@#
NETBIRD_MANAGEMENT_API_PORT=33073
NETBIRD_SIGNAL_PORT=51820

# Docker Socket Proxy
DOCKER_HOST=tcp://docker-proxy:2375

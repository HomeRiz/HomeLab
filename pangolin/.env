# Pangolin Secure Tunnel Configuration
# Pangolin is an open-source alternative to Cloudflare Tunnel

# Server Configuration
PANGOLIN_SERVER_ADDR=0.0.0.0:8443
PANGOLIN_SERVER_TLS=true

# Client Configuration
PANGOLIN_CLIENT_ENABLED=true
PANGOLIN_CLIENT_REMOTE=change_me_pangolin_server_address

# Token for authentication
PANGOLIN_AUTH_TOKEN=change_me_secure_token

# Domain configuration
PANGOLIN_DOMAIN=homelab.example.com

# Service routing
PANGOLIN_SERVICE_VAULTWARDEN=http://vaultwarden:80
PANGOLIN_SERVICE_DASHBOARD=http://homepage:3000
PANGOLIN_SERVICE_ADGUARD=http://adguardhome:8080

# Logging
PANGOLIN_LOG_LEVEL=info

# Performance
PANGOLIN_MAX_CONNECTIONS=1000
PANGOLIN_BUFFER_SIZE=65536
